# ──────────────────────────────────────────────
# DRENZO AI — Environment Variables (Example)
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_API_KEY=your-api-key

# OpenCode Zen API
VITE_OPENCODE_API_URL=https://opencode.ai/zen/v1
VITE_OPENCODE_API_KEY=sk-your-api-key
VITE_OPENCODE_MODEL=deepseek-v4-flash-free

# ─── Vercel-only (set in Vercel Dashboard, NOT in .env) ───
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=Drenzo AI
